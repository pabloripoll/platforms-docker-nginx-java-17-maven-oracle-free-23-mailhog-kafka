# REMOVE COMMENTS WHEN COPY THIS FILE AND TRIM TRAILING WHITESPACES
# Ask the team for recommended values

# DOCKER VARIABLES FOR AUTOMATION
SUDO=sudo                                               # <- how local user executes system commands - leave it empty if not necessary ----------------------> #
DOCKER=sudo docker                                      # <- how local user executes Docker commands --------------------------------------------------------> #
DOCKER_COMPOSE=sudo docker compose                      # <- how local user executes "docker compose" or docker-compose command -----------------------------> #

# CONTAINERS BASE INFORMATION FOR BUILDING WITH docker-compose.yml
PROJECT_NAME="PLATFORMS DOCKER"                         # <- project name will be used for automation outputs -----------------------------------------------> #
PROJECT_LEAD=myproj                                     # <- lead abbreviation or acronym as part of related containers naming rule -------------------------> #
PROJECT_HOST="127.0.0.1"                                # <- machine hostname referrer - not necessary for this project -------------------------------------> #
PROJECT_CNET=mp-dev                                     # <- useful when a network is required for container connections between each other -----------------> #

# API - LOCAL
APIREST_PLTF=nginx-java-17                              # <- platform assets directory's name ---------------------------------------------------------------> #
APIREST_IMGK=alpine-3.24-nginx-java-17                  # <- real main image keys to manage automations for sharing resources -------------------------------> #
APIREST_PORT=7710                                       # <- local machine port opened for container service ------------------------------------------------> #
APIREST_BIND="../../../api-rest"                        # <- path where application is binded from container to local ---------------------------------------> #
APIREST_CAAS=mp-apirest-dev                             # <- container name to build the service - it is important to set the environment in this variable --> #
APIREST_CAAS_USER=osuser                                # <- container's project directory user -------------------------------------------------------------> #
APIREST_CAAS_GROUP=osgroup                              # <- container's project directory group ------------------------------------------------------------> #
APIREST_CAAS_CPUS=2.00                                  # <- container's maximum CPUs usage to apply by docker-compose - leave it empty for full usage ------> #
APIREST_CAAS_MEM=128M                                   # <- container's maximum RAM usage to apply by docker-compose ---------------------------------------> #
APIREST_CAAS_SWAP=256M                                  # <- container's RAM swap space in storage executed by automation command ---------------------------> #

# DATABASE - LOCAL
DATABASE_PLTF=oracle-free-23                            # <- platform assets directory's name ---------------------------------------------------------------> #
DATABASE_IMGK="gvenzl/oracle-free:23-slim-faststart"    # <- real main image keys to manage automations for sharing resources -------------------------------> #
DATABASE_PORT=7711                                      # <- local machine port opened for container service ------------------------------------------------> #
DATABASE_CAAS=mp-oracle-dev                             # <- container name to build the service - it is important to set the environment in this variable --> #
DATABASE_CAAS_CPUS=2.00                                 # <- container's maximum CPUs usage to apply by docker-compose - leave it empty for full usage ------> #
DATABASE_CAAS_MEM=512M                                  # <- container's maximum RAM usage to apply by docker-compose ---------------------------------------> #
DATABASE_CAAS_SWAP=1G                                   # <- container's RAM swap space in storage executed by automation command ---------------------------> #
DATABASE_NAME=dev_local                                 # <- database name & user ---------------------------------------------------------------------------> #
DATABASE_PASS="dev_password"                            # <- database password ------------------------------------------------------------------------------> #
DATABASE_PATH="../../resources/database/"               # <- sql file's directory ---------------------------------------------------------------------------> #
DATABASE_INIT=oracle-init.sql                           # <- init sql file ----------------------------------------------------------------------------------> #
DATABASE_BACK=oracle-backup.sql                         # <- backup sql file --------------------------------------------------------------------------------> #

# MAILER - LOCAL
MAILER_PLTF=mailhog-1.0                                 # <- platform assets directory's name ---------------------------------------------------------------> #
MAILER_IMGK=alpine-3.12-mailhog-1.0                     # <- real main image keys to manage automations for sharing resources -------------------------------> #
MAILER_PORT=7711                                        # <- local machine port opened for container service ------------------------------------------------> #
MAILER_CAAS=mp-mailhog-dev                              # <- container name to build the service - it is important to set the environment in this variable --> #
MAILER_CAAS_CPUS=2.00                                   # <- container's maximum CPUs usage to apply by docker-compose - leave it empty for full usage ------> #
MAILER_CAAS_MEM=128M                                    # <- container's maximum RAM usage to apply by docker-compose ---------------------------------------> #
MAILER_CAAS_SWAP=256M                                   # <- container's RAM swap space in storage executed by automation command ---------------------------> #
MAILER_APP_PORT=7712                                    # <- application ui management port -----------------------------------------------------------------> #

# BROKER - LOCAL
BROKER_PLTF=kafka-3.9                                   # <- platform assets directory's name ---------------------------------------------------------------> #
BROKER_IMGK="apache/kafka:3.9.2"                        # <- real main image keys to manage automations for sharing resources -------------------------------> #
BROKER_PORT_PTEXT=9092                                  # <- local machine port opened for container service - plaintext client traffic ---------------------> #
BROKER_PORT_CNTRL=9093                                  # <- local machine port opened for container service - ssl/tls or control-plane traffic -------------> #
BROKER_DATA="../data"                                   # <- platform broker data storage in local ----------------------------------------------------------> #
BROKER_LOGS="../logs"                                   # <- platform broker logs storage in local ----------------------------------------------------------> #
BROKER_CAAS=mp-kafka-dev                                # <- container name to build the service - it is important to set the environment in this variable --> #
BROKER_CAAS_CPUS=2.00                                   # <- container's maximum CPUs usage to apply by docker-compose - leave it empty for full usage ------> #
BROKER_CAAS_MEM=256M                                    # <- container's maximum RAM usage to apply by docker-compose ---------------------------------------> #
BROKER_CAAS_SWAP=512M                                   # <- container's RAM swap space in storage executed by automation command ---------------------------> #
BROKER_APP_IMGK="provectuslabs/kafka-ui:latest"         # <- application ui management port -----------------------------------------------------------------> #
BROKER_APP_PORT=9094                                    # <- application ui management port -----------------------------------------------------------------> #
BROKER_APP_USER=guest                                   # <- application ui management user -----------------------------------------------------------------> #
BROKER_APP_PASS="guest"                                 # <- application ui management password -------------------------------------------------------------> #